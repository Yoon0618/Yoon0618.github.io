---
import type { TermGroup } from "../utils/content";

interface Props {
  title: string;
  terms: TermGroup[];
  basePath: string;
}

const { title, terms, basePath } = Astro.props;
---

<section class="term-block">
  <div class="section-heading">
    <p class="section-kicker">Taxonomy</p>
    <h2>{title}</h2>
  </div>

  <div class="term-list">
    {
      terms.map((term) => (
        <a class="term-pill" href={`${basePath}/${term.slug}/`}>
          <span>{term.label}</span>
          <span>{term.count}</span>
        </a>
      ))
    }
  </div>
</section>
