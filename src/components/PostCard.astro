---
import type { PostEntry } from "../utils/content";
import { formatDate, getTypeLabel, slugifyTerm } from "../utils/content";

interface Props {
  post: PostEntry;
  compact?: boolean;
}

const { post, compact = false } = Astro.props;
const locale = post.data.lang === "en" ? "en-US" : "ko-KR";
---

<article class:list={["post-card", compact && "is-compact"]}>
  <div class="post-meta-row">
    <span class="post-chip">{getTypeLabel(post.data.type)}</span>
    <span class="post-meta">{post.data.category}</span>
    <span class="post-meta">{formatDate(post.data.pubDate, locale)}</span>
    {post.data.lang === "en" && <span class="post-meta">EN</span>}
  </div>

  <h3 class="post-card-title">
    <a href={`/posts/${post.id}/`}>{post.data.title}</a>
  </h3>

  <p class="post-card-description">{post.data.description}</p>

  <div class="post-tag-row">
    {
      post.data.tags.map((tag) => (
        <a class="post-tag" href={`/tags/${slugifyTerm(tag)}/`}>
          #{tag}
        </a>
      ))
    }
  </div>
</article>
