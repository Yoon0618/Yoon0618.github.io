---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";
import TermList from "../components/TermList.astro";
import {
  getCategories,
  getPublishedPosts,
  getSeries,
  getTags
} from "../utils/content";

const posts = getPublishedPosts(await getCollection("posts"));
const recentPosts = posts.slice(0, 4);
const series = getSeries(posts);
const categories = getCategories(posts);
const tags = getTags(posts).slice(0, 10);
---

<BaseLayout
  title="Plasma Physics Notebook"
  description="플라즈마 물리를 공부하며 정리한 노트와 긴 정리글을 모아두는 아카이브."
>
  <section class="hero-section">
    <div class="hero-backdrop"></div>
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="page-eyebrow">Plasma Physics Study Archive</p>
        <h1>개념이 연결되는 순간을 붙잡아두는 플라즈마 물리 노트북.</h1>
        <p class="page-intro">
          짧은 학습 메모와 긴 정리글을 한 곳에 쌓아두며, Debye shielding부터
          진단과 수송까지 공부 흐름을 천천히 기록합니다.
        </p>

        <div class="hero-actions">
          <a class="button-primary" href="/posts">최근 기록 읽기</a>
          <a class="button-secondary" href="/about">공부 방식 보기</a>
        </div>
      </div>

      <div class="hero-panel">
        <p class="hero-panel-kicker">Focus Now</p>
        <ul class="hero-notes">
          <li>Debye length와 quasi-neutrality의 연결</li>
          <li>Langmuir probe 해석에서의 전류-전압 곡선 읽기</li>
          <li>짧은 노트와 긴 정리글을 같은 아카이브에서 운영</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="container section-spacing">
    <div class="section-heading">
      <p class="section-kicker">Recent</p>
      <h2>최근 기록</h2>
      <p>
        공부 중 바로 붙잡아 둔 메모와, 한 번 더 정리한 글을 시간순으로 모아
        봅니다.
      </p>
    </div>

    <div class="post-grid">
      {recentPosts.map((post) => <PostCard post={post} />)}
    </div>
  </section>

  <section class="container section-spacing section-series">
    <div class="section-heading">
      <p class="section-kicker">Series</p>
      <h2>연속적으로 보는 주제</h2>
      <p>기초 개념과 진단 주제를 시리즈 단위로 이어서 읽을 수 있습니다.</p>
    </div>

    <div class="series-list">
      {
        series.map((item) => (
          <a class="series-row" href={`/series/${item.slug}/`}>
            <div>
              <p class="series-label">{item.label}</p>
              <p class="series-detail">
                {item.posts[0]?.data.description}
              </p>
            </div>
            <span>{item.count} posts</span>
          </a>
        ))
      }
    </div>
  </section>

  <section class="container taxonomy-grid section-spacing">
    <TermList title="Categories" terms={categories} basePath="/categories" />
    <TermList title="Popular Tags" terms={tags} basePath="/tags" />
  </section>

  <section class="container section-spacing about-strip">
    <div class="section-heading">
      <p class="section-kicker">About This Notebook</p>
      <h2>왜 이렇게 기록하나요?</h2>
    </div>
    <p>
      수식과 직관이 연결되는 지점을 놓치지 않기 위해, 읽은 내용을 짧게 저장하고
      나중에 더 긴 문장으로 다시 정리합니다. 이 블로그는 그 반복의 흔적을 모아둔
      작업대입니다.
    </p>
    <a class="text-link" href="/about">더 보기</a>
  </section>
</BaseLayout>
