---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";
import TermList from "../components/TermList.astro";
import {
  getCategories,
  getPublishedPosts,
  getSeries,
  getTags
} from "../utils/content";

const posts = getPublishedPosts(await getCollection("posts"));
const recentPosts = posts.slice(0, 4);
const series = getSeries(posts);
const categories = getCategories(posts);
const tags = getTags(posts).slice(0, 10);
---

<BaseLayout
  title="Plasma Physics Notebook"
  description="플라즈마 물리를 공부하며 정리한 노트와 긴 정리글을 모아두는 아카이브."
>
  <section class="hero-section">
    <div class="hero-media" aria-hidden="true"></div>
    <div class="hero-overlay" aria-hidden="true"></div>
    <div class="container hero-inner">
      <div class="hero-copy">
        <p class="page-eyebrow">Plasma Physics Notebook</p>
        <h1>플라즈마 물리 공부를 천천히 쌓아두는 개인 노트.</h1>
        <p class="page-intro">
          짧은 메모와 긴 정리글을 같은 흐름 안에 두고, 헷갈렸던 개념과 다시 보고
          싶은 계산을 조용히 축적합니다.
        </p>

        <div class="hero-actions">
          <a class="button-primary" href="/posts">기록 보기</a>
          <a class="button-secondary" href="/about">노트 방식</a>
        </div>
      </div>
    </div>
  </section>

  <section class="container hero-strip">
    <div class="hero-strip-item">
      <span class="strip-label">Now reading</span>
      <p>Debye length와 quasi-neutrality의 연결</p>
    </div>
    <div class="hero-strip-item">
      <span class="strip-label">Next note</span>
      <p>Langmuir probe I-V 곡선의 전자 영역 읽기</p>
    </div>
    <div class="hero-strip-item">
      <span class="strip-label">Writing mode</span>
      <p>짧은 note와 긴 article을 같은 아카이브에서 운영</p>
    </div>
  </section>

  <section class="container section-spacing">
    <div class="section-heading">
      <p class="section-kicker">Recent</p>
      <h2>최근 기록</h2>
      <p>
        최근에 적은 노트와 정리글을 시간순으로 정리했습니다.
      </p>
    </div>

    <div class="post-grid">
      {recentPosts.map((post) => <PostCard post={post} />)}
    </div>
  </section>

  <section class="container section-spacing section-series">
    <div class="section-heading">
      <p class="section-kicker">Series</p>
      <h2>연속적으로 보는 주제</h2>
      <p>같은 주제를 단계적으로 다시 읽기 좋게 묶었습니다.</p>
    </div>

    <div class="series-list">
      {
        series.map((item) => (
          <a class="series-row" href={`/series/${item.slug}/`}>
            <div>
              <p class="series-label">{item.label}</p>
              <p class="series-detail">
                {item.posts[0]?.data.description}
              </p>
            </div>
            <span>{item.count} posts</span>
          </a>
        ))
      }
    </div>
  </section>

  <section class="container taxonomy-grid section-spacing">
    <TermList title="Categories" terms={categories} basePath="/categories" />
    <TermList title="Popular Tags" terms={tags} basePath="/tags" />
  </section>

  <section class="container section-spacing about-strip">
    <div class="section-heading">
      <p class="section-kicker">About This Notebook</p>
      <h2>왜 이렇게 기록하나요?</h2>
    </div>
    <p>
      읽은 내용을 바로 저장해 두고, 나중에 설명 가능한 문장으로 다시 정리하기
      위해서입니다. 이 블로그는 그 반복을 오래 남겨두기 위한 작업대입니다.
    </p>
    <a class="text-link" href="/about">더 보기</a>
  </section>
</BaseLayout>
